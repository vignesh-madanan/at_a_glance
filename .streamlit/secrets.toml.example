# Copy this file to secrets.toml and add your API keys
# DO NOT commit secrets.toml to version control

# OpenWeatherMap API key (optional - app works without it)
# Get one at: https://openweathermap.org/api
weather_api_key = "YOUR_OPENWEATHER_API_KEY"

# MTA API key (optional - app uses mock data without it)
# Get one at: https://api.mta.info/
mta_api_key = "YOUR_MTA_API_KEY"
